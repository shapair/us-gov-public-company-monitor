# Backend
DATABASE_URL=postgresql+psycopg2://postgres:postgres@db:5432/govmonitor
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
SCHEDULER_ENABLED=true
USASPENDING_BASE_URL=https://api.usaspending.gov
SEC_USER_AGENT=USGovMonitor/1.0 (contact@example.com)
SEC_TICKERS_URL=https://www.sec.gov/files/company_tickers.json
SEC_SUBMISSIONS_URL=https://data.sec.gov/submissions
FOREIGN_HOLDING_FORMS=13F-HR,13F-HR/A,13D,13D/A,13G,13G/A
FOREIGN_HOLDING_MAX_RESULTS=100

# Optional: host-side CONNECT proxy for environments where Docker containers
# cannot complete TLS handshakes to public APIs. Start it with:
#   python scripts/host_connect_proxy.py
# Leave empty/unset to fetch directly from the container.
# GitHub domains bypass the proxy automatically (they work directly from the
# container); only USASpending/SEC need the tunnel in this environment.
HOST_CONNECT_PROXY_URL=http://host.docker.internal:8788

# Frontend
VITE_API_BASE=http://localhost:8000/api/v1
